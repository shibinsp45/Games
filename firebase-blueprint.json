{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user profile in the application.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The user's display name."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "photoURL": {
          "type": "string",
          "format": "uri",
          "description": "The URL of the user's profile photo."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the user was created."
        }
      },
      "required": ["name", "email", "createdAt"]
    },
    "Room": {
      "title": "Room",
      "description": "A game room for two players.",
      "type": "object",
      "properties": {
        "hostId": {
          "type": "string",
          "description": "The UID of the user who created the room."
        },
        "guestId": {
          "type": "string",
          "description": "The UID of the user who joined the room."
        },
        "status": {
          "type": "string",
          "enum": ["waiting", "playing", "match", "game-over"],
          "description": "The current status of the room."
        },
        "currentQuestion": {
          "type": "string",
          "description": "The current question being asked."
        },
        "hostAnswer": {
          "type": "string",
          "description": "The host's answer to the current question."
        },
        "guestAnswer": {
          "type": "string",
          "description": "The guest's answer to the current question."
        },
        "hostReady": {
          "type": "boolean",
          "description": "Whether the host is ready for the next round."
        },
        "guestReady": {
          "type": "boolean",
          "description": "Whether the guest is ready for the next round."
        },
        "hostScore": {
          "type": "number",
          "description": "The host's score."
        },
        "guestScore": {
          "type": "number",
          "description": "The guest's score."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the room was created."
        }
      },
      "required": ["hostId", "status", "createdAt", "hostScore", "guestScore"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "Stores user profiles."
    },
    "/rooms/{roomId}": {
      "schema": {
        "$ref": "#/entities/Room"
      },
      "description": "Stores game rooms."
    }
  }
}
